# fal.ai API key — get from https://fal.ai/dashboard/keys
FAL_KEY=

# Site URL (used in metadata, sitemap)
NEXT_PUBLIC_SITE_URL=https://magickcoloring.com

# Google Analytics (G-XXXXXXX) — leave blank until set up
NEXT_PUBLIC_GA_ID=

# Google Adsense client ID (ca-pub-XXXX) — leave blank until approved
NEXT_PUBLIC_ADSENSE_CLIENT=

# Stripe (test mode for dev, live mode for production)
STRIPE_SECRET_KEY=
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=
STRIPE_WEBHOOK_SECRET=
STRIPE_PRICE_ONETIME=
STRIPE_PRICE_SUBSCRIPTION=

# Vercel KV (auto-set when you enable KV in Vercel dashboard)
KV_REST_API_URL=
KV_REST_API_TOKEN=
KV_REST_API_READ_ONLY_TOKEN=
KV_URL=

# Vercel Blob (auto-set when you enable Blob in Vercel dashboard)
BLOB_READ_WRITE_TOKEN=
